# ============================================
# DATAVANT Systems - Environment Variables Template
# ============================================
#
# HOW TO USE THIS FILE
#   1. Copy to .env:            cp .env.example .env
#   2. Fill in real values in .env (see CONFIGURATION.md for step-by-step).
#   3. NEVER commit .env to version control (it is in .gitignore).
#
# FAIL-CLOSED CONTRACT
#   The contact form is deliberately disabled when:
#     - SMTP_USER or CONTACT_TO_EMAIL is empty or not a valid email.
#     - SMTP_PASS is empty, or starts/ends with `__` (placeholder sentinel).
#   When any of those are true, /contacto.php renders a "formulario
#   temporalmente no operativo" banner and /send_mail.php returns 503.
#
# ============================================


# ---- Application Mode ------------------------------------------------
# REQUIRED. Controls error verbosity and production hardening.
#   development  -> verbose errors, relaxed cookies
#   production   -> minimal errors, strict cookies (requires APP_URL_SCHEME=https)
APP_ENV=development


# ---- URL Scheme ------------------------------------------------------
# REQUIRED. Determines secure-cookie flag, HSTS and CSP upgrade behaviour.
#   http   -> local/dev
#   https  -> production only (certificate required)
APP_URL_SCHEME=http


# ---- Gmail SMTP Server -----------------------------------------------
# REQUIRED. Defaults target Gmail's submission port (STARTTLS on 587).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=tls


# ---- SMTP Credentials ------------------------------------------------
# REQUIRED. SMTP_USER is the Gmail mailbox that authenticates to send
# mail. SMTP_PASS is an App Password (NEVER your real account password).
#
# Generate an App Password:
#   1. Enable 2-Step Verification: https://myaccount.google.com/security
#   2. Create an app password at: https://myaccount.google.com/apppasswords
#   3. Paste the 16-character string (spaces optional) below.
#
# SAFE PLACEHOLDERS (rejected by mail_is_configured):
#   __ROTATE_ME__, __CHANGE_ME__, or any value starting/ending with `__`.
SMTP_USER=your-email@gmail.com
SMTP_PASS=__ROTATE_ME__


# ---- Sender Identity -------------------------------------------------
# REQUIRED. Gmail forces the From: header to match SMTP_USER, but the
# friendly name and reply-to are under our control.
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=DATAVANT Systems


# ---- Contact Form Recipient ------------------------------------------
# REQUIRED. Inbox that receives submissions from /contacto.php.
# Leave empty to keep the form disabled (fail-closed).
CONTACT_TO_EMAIL=


# ---- Logging Salt ----------------------------------------------------
# REQUIRED. 32-byte hex string used to hash visitor IPs before they are
# written to logs/events_YYYY-MM.log. Rotating this value de-identifies
# historical logs. Never reuse across environments.
#
# Generate a fresh value with:
#   openssl rand -hex 32
#   # or: php -r "echo bin2hex(random_bytes(32));"
LOG_IP_SALT=replace-with-64-character-hex-string
