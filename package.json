{
    "name": "datavant-systems",
    "version": "1.0.0",
    "private": true,
    "description": "Sitio corporativo DATAVANT Systems — PHP + HTML5 + SCSS + Bootstrap 3 + Vanilla JS",
    "scripts": {
        "sass": "sass assets/scss/main.scss assets/css/main.css --style=compressed --no-source-map",
        "sass:watch": "sass --watch assets/scss/main.scss:assets/css/main.css --style=compressed",
        "lint:spell": "cspell --config cspell.json --no-progress --show-context",
        "lint:spell:unknown": "cspell --config cspell.json --no-progress --words-only --unique | sort",
        "lint": "npm run lint:spell"
    },
    "devDependencies": {
        "cspell": "^8.17.0",
        "@cspell/dict-es-es": "^3.0.0",
        "sass": "^1.77.0"
    }
}
