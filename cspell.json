{
    "$schema": "https://raw.githubusercontent.com/streetsidesoftware/cspell/main/cspell.schema.json",
    "version": "0.2",
    "language": "en,es,es-ES",
    "caseSensitive": false,
    "allowCompoundWords": true,
    "import": [
        "@cspell/dict-es-es/cspell-ext.json"
    ],
    "files": [
        "**/*.php",
        "**/*.html",
        "**/*.htm",
        "**/*.js",
        "**/*.css",
        "**/*.scss",
        "**/*.md"
    ],
    "ignorePaths": [
        "node_modules/**",
        "vendor/**",
        "logs/**",
        "assets/css/**",
        "assets/**/*.min.*",
        "favicon.ico",
        "sitemap.xml",
        "robots.txt",
        "docker-compose.yml",
        "Dockerfile",
        "docker-entrypoint.sh",
        ".env",
        ".env.*",
        "skills-lock.json",
        "cspell.json",
        ".editorconfig",
        "package-lock.json"
    ],
    "dictionaries": [
        "es-es",
        "datavant",
        "tech"
    ],
