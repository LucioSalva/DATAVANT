    "overrides": [
        {
            "filename": "**/*.php",
            "ignoreRegExpList": [
                "/<\\?(php|=)[\\s\\S]*?\\?>/g",
                "/\\$[a-zA-Z_][a-zA-Z0-9_]*/g",
                "/name=\"[^\"]+\"/g",
                "/id=\"[^\"]+\"/g",
                "/class=\"[^\"]+\"/g",
                "/href=\"[^\"]+\"/g",
                "/src=\"[^\"]+\"/g",
                "/action=\"[^\"]+\"/g",
                "/<code>[\\s\\S]*?<\\/code>/g",
                "/<pre[\\s\\S]*?<\\/pre>/g"
            ]
        },
        {
            "filename": "**/*.{js,css,scss}",
            "ignoreRegExpList": [
                "/#[a-zA-Z_][a-zA-Z0-9_-]*/g",
                "/\\.[a-zA-Z_][a-zA-Z0-9_-]*/g",
                "/--[a-zA-Z0-9_-]+/g"
            ]
        }
    ]
}
