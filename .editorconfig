# EditorConfig — DATAVANT Systems
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{md,markdown}]
trim_trailing_whitespace = false
indent_size = 2

[*.{yml,yaml,json}]
indent_size = 2

[*.{js,css,scss,html,htm}]
indent_size = 4

[*.php]
indent_size = 4

[Makefile]
indent_style = tab
